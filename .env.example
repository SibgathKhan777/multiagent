# ── AI Provider ────────────────────────────────────────────────────────────────
# Options: groq | gemini | python-ai | simulated
PROVIDER=groq

# ── Groq (https://console.groq.com) ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Google Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Python AI Service (hybrid mode) ───────────────────────────────────────────
# URL of the running multiagent-ai-service (FastAPI + CrewAI + LangGraph).
# Required when PROVIDER=python-ai.
AI_SERVICE_URL=http://localhost:8000

# ── Infrastructure ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/multiagent
REDIS_URL=redis://localhost:6379

# ── Pipeline tuning ───────────────────────────────────────────────────────────
QUALITY_THRESHOLD=70
MAX_ITERATIONS=3
LOG_LEVEL=info
